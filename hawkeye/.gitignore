# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/

# Data — raw videos and images not tracked
data/raw/
data/annotated/
data/augmented/
data/clean_frames/
data/patchcore_bank/

# Model weights — excluded by default (large files)
models/
