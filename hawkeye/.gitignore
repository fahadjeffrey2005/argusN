!models/yolo/
!models/yolo/finetuned/
!models/yolo/finetuned/best.pt
!models/patchcore/
!models/patchcore/bank.pt

# Outputs — transfer via scp/Google Drive
outputs/

# Video files — blocked at file level too
*.mp4
*.avi
*.mov
*.mkv

# Logs — exclude verbose logs, track eval results
logs/
!logs/eval_results.json
!logs/hawkeye_results.md
!logs/retrain_history.json

